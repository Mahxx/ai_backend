PORT=8787
ALLOWED_ORIGINS=*
NODE_ENV=development

# Backend identity. Each deployed backend must have a unique BACKEND_ID.
BACKEND_ID=backend-1
BACKEND_TYPE=render
BACKEND_PUBLIC_URL=http://localhost:8787

# Supabase Postgres. Keep the service role key only on the backend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Course storage.
# Use cloudflare-pages for a free public CDN, or cloudflare-r2 for private R2.
COURSE_STORAGE_PROVIDER=cloudflare-pages
COURSE_CONTENT_BASE_URL=https://qcm-edu-ai-courses.pages.dev/

# Optional private Cloudflare R2 configuration.
R2_ACCOUNT_ID=
R2_BUCKET_NAME=qcm-edu-ai-courses
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
COURSE_TEXT_CACHE_MAX_MB=256
COURSE_TEXT_CACHE_TTL_MINUTES=720

# Optional fallback: Oracle Object Storage through the S3-compatible API.
ORACLE_REGION=
ORACLE_NAMESPACE=
ORACLE_BUCKET_NAME=
ORACLE_ACCESS_KEY=
ORACLE_SECRET_KEY=

# 32+ random characters. Never commit the real value.
MASTER_ENCRYPTION_KEY=

# Limits
MAX_FILE_SIZE_MB=2
MAX_FILES=1
USER_DAILY_LIMIT=5
MAX_SUBJECT_CHARS=20000
MAX_COURSE_CONTEXT_CHARS=50000
REQUEST_TIMEOUT_MS=60000

# Optional legacy server-owned keys. The new flow uses user-owned encrypted keys.
AI_PROVIDER_ORDER=openai,deepseek,gemini,anthropic,grok
OPENAI_MODEL=gpt-4o-mini
DEEPSEEK_MODEL=deepseek-chat
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
GROK_MODEL=grok-2-latest
